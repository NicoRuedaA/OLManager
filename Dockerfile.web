# ─── Build stage: compile the web-mode SPA ──────────────────────
FROM node:22-bookworm-slim AS builder

WORKDIR /app

# Install deps first (better layer caching).
COPY package.json package-lock.json ./
RUN npm ci

# App sources needed by `vite build --mode web`.
COPY . .

# VITE_* vars are baked at build time. VITE_API_BASE is left empty so the
# frontend calls /api on the same origin (nginx proxies it to the backend).
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_PUBLISHABLE_KEY
RUN printf 'VITE_SUPABASE_URL=%s\nVITE_SUPABASE_PUBLISHABLE_KEY=%s\nVITE_API_BASE=\n' \
      "$VITE_SUPABASE_URL" "$VITE_SUPABASE_PUBLISHABLE_KEY" > .env \
    && npm run build:web

# ─── Runtime stage: nginx serves dist/ + proxies /api ───────────
FROM nginx:1.27-alpine AS runtime

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
