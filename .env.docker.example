# Copy to `.env` on the server and fill in the values:
#   cp .env.docker.example .env
# docker compose reads this file for build args (VITE_*) and backend runtime env.

# ─── Frontend (baked into the build) ────────────────────────────
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Leave VITE_API_BASE unset → frontend calls /api on the same origin (nginx proxy).

# ─── Backend (Rust server, runtime) ─────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json

# Postgres via the Supabase SESSION pooler (IPv4). Percent-encode reserved
# chars in the password (e.g. '@' → %40). Append ?sslmode=require.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ─── Host port nginx is published on ────────────────────────────
WEB_PORT=8080

# ─── Optional: enable the data import-export endpoints ──────────
# OLM_ALLOW_IMPORT=1
# OLM_IMPORT_SOURCE=https://olmdb-manager.vercel.app/api/olm/export
