{
  "name": "olmanager-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Leaguepedia scraper for OLManager — extracts players, teams, and images from all pro LoL leagues",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "scrape": "tsx src/index.ts --skip-images",
    "scrape:full": "tsx src/index.ts",
    "explore": "tsx src/explore.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "p-limit": "^4.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
